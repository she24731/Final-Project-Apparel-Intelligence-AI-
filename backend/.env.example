# Copy to .env and fill in. Leave GEMINI_API_KEY blank to use deterministic fallbacks.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATA_DIR=./data

# Media (provider adapter selection is implemented; real APIs are stubbed)
MEDIA_PROVIDER=mock
RUNWAY_API_KEY=
