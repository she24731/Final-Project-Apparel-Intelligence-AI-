# Copy to `backend/.env` and add your key. Never commit `.env`.
# Leave GEMINI_API_KEY empty for deterministic offline demos (CI uses this).

GEMINI_API_KEY=
# Text + structured agents (scripts, styling, wardrobe, concierge chat)
GEMINI_MODEL=gemini-2.5-flash

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_API_BASE_URL=http://127.0.0.1:8000

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATA_DIR=./data

# Video generation (Veo via Gemini API). Requires GEMINI_API_KEY + billing / allowlisted project.
# - veo-3.1-generate-preview — latest quality-focused preview (see Google AI video docs).
# - veo-3.1-generate-001 — often used as the “fast” / stable production id when available in your region.
# - veo-2.0-generate-001 — older generation; may be cheaper or broader availability.
MEDIA_PROVIDER=gemini_video
GEMINI_VIDEO_MODEL=veo-3.1-generate-preview
RUNWAY_API_KEY=
